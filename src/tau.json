{
  "timeout": 180,
  "agent_name": "default",
  "debug": false,
  "malformed": {
    "silent_retries": 4,
    "enhanced_retries": 7,
    "explicit_retries": 10
  },
  "loop_detection": {
    "window_size": 30,
    "repeat_threshold": 3,
    "replace_unknown_tools": 2
  },
  "nesting": {
    "depth_threshold": 2
  },
  "external_services": {
    "searxng_url": "http://searxng",
    "crawl4ai_url": "http://crawl4ai:11235"
  },
  "reflection": {
    "enabled": false,
    "initial_think": false,
    "min_interval": 15,
    "max_interval": 30,
    "content_threshold_bytes": 200,
    "reactive_on_loop_warning": true,
    "reactive_on_error_burst": true
  },
  "llm_groups": {
    "cuda": {
      "model": "model",
      "api_base": "http://cuda:8000/v1",
      "api_key": "",
      "timeout": 600,
      "max_context_tokens": 180000,
      "max_tokens": 12000,
      "temperature": 0.6,
      "top_p": 0.95,
      "top_k": 20,
      "min_p": 0.0,
      "presence_penalty": 0.0,
      "repetition_penalty": 1.0,
